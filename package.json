{
  "name": "solo-founder-agents",
  "version": "0.2.0",
  "description": "24/7 AI assistant system for solo founders — Discord/Slack/Telegram bot + scheduled routines + team-based agents",
  "type": "module",
  "bin": {
    "solo-agents": "./dist/bin/solo-agents.js"
  },
  "main": "./dist/src/index.js",
  "files": [
    "dist/",
    "assets/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx bin/solo-agents.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "discord.js": "^14.16.0",
    "@slack/bolt": "^4.1.0",
    "@slack/web-api": "^7.8.0",
    "node-telegram-bot-api": "^0.66.0",
    "node-cron": "^3.0.3",
    "commander": "^12.1.0",
    "chalk": "^5.4.1",
    "inquirer": "^12.3.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/js-yaml": "^4.0.9",
    "@types/inquirer": "^9.0.7"
  },
  "engines": {
    "node": ">=18"
