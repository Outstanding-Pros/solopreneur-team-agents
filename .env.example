# ──────────────────────────────────────────────
# solopreneur-agents 설정
# cp .env.example .env 후 아래 값만 채우세요
# ──────────────────────────────────────────────

# 1. 오너 정보 (당신에 대한 설명)
OWNER_NAME=
OWNER_ROLE=

# 2. Discord Bot Token
#    만드는 법: https://discord.com/developers/applications
#    → New Application → Bot → Reset Token
DISCORD_TOKEN=your-discord-bot-token-here

# 3. GitHub Personal Access Token (선택 - 레포 자동 생성용)
#    만드는 법: GitHub Settings → Developer settings → PAT → Fine-grained
#    권한: repo (read/write), org (read)
GITHUB_TOKEN=your-github-token-here

# 4. 로컬 repos 경로 (프로젝트들이 클론될 위치)
#    Windows 예시: C:/Users/yourname/repos
#    Mac 예시: /Users/yourname/repos
REPOS_BASE_PATH=./repos

# ──────────────────────────────────────────────
# 아래는 setup.py가 자동으로 채워줍니다
# ──────────────────────────────────────────────
# DISCORD_APP_ID=
# DISCORD_GUILD_IDS=
# PRODUCTS=
