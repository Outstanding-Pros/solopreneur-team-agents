# ──────────────────────────────────────────────
# Solo Founder Agents Configuration
# cp .env.example .env and fill in the values below
# ──────────────────────────────────────────────

# 1. Owner info
OWNER_NAME=
OWNER_ROLE=

# 2. Messenger platform (discord / slack / telegram)
#    Multiple platforms: MESSENGER=discord,slack
MESSENGER=discord

# 3. Discord settings (if MESSENGER=discord)
#    Create at: https://discord.com/developers/applications
#    → New Application → Bot → Reset Token
DISCORD_TOKEN=your-discord-bot-token-here

# 4. Slack settings (if MESSENGER=slack)
#    Create at: https://api.slack.com/apps
#    → Create New App → OAuth & Permissions → Bot Token
#    → Socket Mode → Enable → App-Level Token
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_COMMAND_CHANNEL=owner-command

# 5. Telegram settings (if MESSENGER=telegram)
#    Create bot via @BotFather on Telegram
#    Get chat ID via @userinfobot or @getidsbot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# 6. GitHub Personal Access Token (optional - for auto repo creation)
#    Create at: GitHub Settings → Developer settings → PAT → Fine-grained
#    Permissions: repo (read/write), org (read)
GITHUB_TOKEN=your-github-token-here

# 7. Local repos path (where projects will be cloned)
#    Windows: C:/Users/yourname/repos
#    Mac: /Users/yourname/repos
REPOS_BASE_PATH=./repos

# ──────────────────────────────────────────────
# Below are auto-filled by setup.py
# ──────────────────────────────────────────────
# DISCORD_APP_ID=
# PRODUCTS=
